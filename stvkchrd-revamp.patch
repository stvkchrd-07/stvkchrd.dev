+                .then(({ data, error }) => {
+                    if (error || !data || data.length === 0) {
+                        initCWO(sampleWorkingOn);
+                    } else {
+                        initCWO(data);
+                    }
+                });
+        } catch(e) {
+            initCWO(sampleWorkingOn);
+        }
+    } else {
+        initCWO(sampleWorkingOn);
+    }
+});
