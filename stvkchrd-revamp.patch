+const sampleWorkingOn = [
+    {
+        title: "TheCommonCo",
+        tag: "Streetwear / Merch",
+        description: "Scaling bulk corporate merch orders. Working on overseas pricing models and influencer outreach campaigns.",
+        status: "Active"
