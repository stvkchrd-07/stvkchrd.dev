+function showCopyToast(email) {
+    const toast = document.getElementById('copy-toast');
+    if (!toast) return;
+    toast.textContent = `${email} copied to clipboard`;
+    toast.classList.add('show');
+    setTimeout(() => toast.classList.remove('show'), 800);
+}
